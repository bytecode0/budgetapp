generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  settings       UserSettings?
  subscription   Subscription?
  lifePlans      LifePlan[]
  allocations    Allocation[]
  expenses       Expense[]
  planDeposits   PlanDeposit[]
  monthlyBudgets MonthlyBudget[]
  categorizationRules CategorizationRule[]
  accounts       Account[]
  sentInvites    PartnerInvite[] @relation("SentInvites")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  plan                 String    @default("free")   // "free" | "premium"
  status               String?                       // active | past_due | cancelled | trialing | ...
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id            String  @id @default(cuid())
  userId        String  @unique
  monthlyIncome Int     @default(0) // cents
  darkMode      Boolean @default(false)
  language      String  @default("en")
  linkedUserId  String? // Points to primary user's id when this is a linked (partner) account

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LifePlan {
  id                  String    @id @default(cuid())
  userId              String
  title               String
  description         String    @default("")
  goalClass           String    @default("savings") // "savings" | "investment"
  type                String    @default("other")
  icon                String    @default("🎯")
  color               String    @default("#1E3A8A")
  targetAmount        Int                  // cents
  currentAmount       Int       @default(0) // cents
  monthlyContribution Int       @default(0) // cents
  deadline            DateTime?
  milestones          String    @default("[]") // JSON array of milestone amounts (investment plans)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deposits    PlanDeposit[]
  allocations Allocation[]
}

model Allocation {
  id              String  @id @default(cuid())
  userId          String
  name            String
  icon            String  @default("💰")
  type            String  @default("flexible") // fixed | flexible | plan
  lifePlanId      String?
  allocatedAmount Int     @default(0) // cents
  actualAmount    Int     @default(0) // cents
  sortOrder       Int     @default(0)
  isDefault       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifePlan       LifePlan?       @relation(fields: [lifePlanId], references: [id], onDelete: SetNull)
  expenses       Expense[]
  monthlyBudgets MonthlyBudget[]
  categorizationRules CategorizationRule[]
}

model Expense {
  id           String   @id @default(cuid())
  userId       String
  allocationId String?
  accountId    String? // bank account this expense was paid from (Phase E)
  amount       Int // cents
  description  String   @default("")
  merchant     String   @default("") // normalized form of description (see server/lib/normalizeMerchant.ts)
  source       String   @default("manual") // "manual" | "import"
  externalId   String? // idempotency key for future bank import; null for manual entries
  date         DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocation Allocation? @relation(fields: [allocationId], references: [id], onDelete: SetNull)
  account    Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@unique([userId, externalId]) // dedupe imported rows; multiple NULLs allowed in Postgres
  @@index([userId, merchant])
  @@index([userId, accountId])
}

model Account {
  id             String  @id @default(cuid())
  userId         String  // shared pool (primary user in couples)
  ownerUserId    String  // real owner (req.authUserId) — per-person attribution
  name           String
  type           String  @default("checking") // checking | savings | cash | investment | card
  currency       String  @default("EUR")
  currentBalance Int     @default(0) // cents; may be negative (cards/debt)
  isArchived     Boolean @default(false)
  sortOrder      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([userId, sortOrder])
}

model CategorizationRule {
  id           String @id @default(cuid())
  userId       String
  matchType    String @default("contains") // "contains" | "equals" | "regex"
  pattern      String // matched against the expense merchant (contains/equals) or description (regex)
  allocationId String
  priority     Int    @default(0) // higher wins on conflict
  source       String @default("manual") // "manual" | "learned" (auto-created from a user correction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocation Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@unique([userId, matchType, pattern]) // one rule per (matchType, pattern); enables upsert on learning
  @@index([userId, priority])
}


model PlanDeposit {
  id      String @id @default(cuid())
  userId  String
  planId  String
  amount  Int // cents
  month   String // "2026-04"
  note    String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan LifePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, month])
}

model MonthlyBudget {
  id             String @id @default(cuid())
  userId         String
  allocationId   String
  month          String // "2026-04"
  allocatedAmount Int // cents

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocation Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@unique([allocationId, month])
}

model PartnerInvite {
  id           String   @id @default(cuid())
  senderId     String
  invitedEmail String
  token        String   @unique
  status       String   @default("pending") // pending | accepted
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  sender User @relation("SentInvites", fields: [senderId], references: [id], onDelete: Cascade)
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, type])
}
