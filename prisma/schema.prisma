generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  settings       UserSettings?
  subscription   Subscription?
  lifePlans      LifePlan[]
  allocations    Allocation[]
  expenses       Expense[]
  planDeposits   PlanDeposit[]
  monthlyBudgets MonthlyBudget[]
  categorizationRules CategorizationRule[]
  accounts       Account[]
  incomes        Income[]
  recurringCommitments RecurringCommitment[]
  sentInvites    PartnerInvite[] @relation("SentInvites")
  householdMemberships HouseholdMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  plan                 String    @default("free")   // "free" | "premium"
  status               String?                       // active | past_due | cancelled | trialing | ...
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id            String  @id @default(cuid())
  userId        String  @unique
  monthlyIncome Int     @default(0) // cents
  darkMode      Boolean @default(false)
  language      String  @default("en")
  linkedUserId  String? // Points to primary user's id when this is a linked (partner) account

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LifePlan {
  id                  String    @id @default(cuid())
  userId              String
  title               String
  description         String    @default("")
  goalClass           String    @default("savings") // "savings" | "investment"
  type                String    @default("other")
  icon                String    @default("🎯")
  color               String    @default("#1E3A8A")
  targetAmount        Int                  // cents
  currentAmount       Int       @default(0) // cents
  monthlyContribution Int       @default(0) // cents
  deadline            DateTime?
  milestones          String    @default("[]") // JSON array of milestone amounts (investment plans)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deposits    PlanDeposit[]
  allocations Allocation[]
}

model Allocation {
  id              String  @id @default(cuid())
  userId          String
  name            String
  icon            String  @default("💰")
  type            String  @default("flexible") // fixed | flexible | plan
  lifePlanId      String?
  allocatedAmount Int     @default(0) // cents
  actualAmount    Int     @default(0) // cents
  sortOrder       Int     @default(0)
  isDefault       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifePlan       LifePlan?       @relation(fields: [lifePlanId], references: [id], onDelete: SetNull)
  expenses       Expense[]
  monthlyBudgets MonthlyBudget[]
  categorizationRules CategorizationRule[]
  recurringCommitments RecurringCommitment[]
}

model RecurringCommitment {
  id               String    @id @default(cuid())
  userId           String
  merchant         String    // normalized merchant the commitment recurs on
  avgAmount        Int       // cents
  cadence          String    @default("monthly") // monthly (only cadence detected today)
  allocationId     String?   // linked fixed allocation once confirmed
  nextExpectedDate DateTime?
  status           String    @default("detected") // detected | confirmed | ignored

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocation Allocation? @relation(fields: [allocationId], references: [id], onDelete: SetNull)

  @@unique([userId, merchant]) // one commitment per merchant; enables upsert on re-detection
}

model Expense {
  id           String   @id @default(cuid())
  userId       String
  allocationId String?
  accountId    String? // bank account this expense was paid from (Phase E)
  amount       Int // cents
  description  String   @default("")
  merchant     String   @default("") // normalized form of description (see server/lib/normalizeMerchant.ts)
  source       String   @default("manual") // "manual" | "import"
  externalId   String? // idempotency key for future bank import; null for manual entries
  date         DateTime @default(now())

  // Attribution (Epic H3) — who paid, who benefits, how it's split.
  payerUserId       String? // who actually paid (real person); null for legacy rows
  scope             String  @default("personal") // personal | shared
  beneficiaryUserId String? // when scope=personal and beneficiary ≠ payer
  scopeConfidence   Float?  // 0..1 when scope was set by AI
  scopeSource       String  @default("manual") // manual | ai | rule

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocation Allocation? @relation(fields: [allocationId], references: [id], onDelete: SetNull)
  account    Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  shares     ExpenseShare[]

  @@unique([userId, externalId]) // dedupe imported rows; multiple NULLs allowed in Postgres
  @@index([userId, merchant])
  @@index([userId, accountId])
}

// The distribution of a shared expense across household members (Epic H3).
// Σ shares.amount == expense.amount (rounding residue assigned to the payer).
model ExpenseShare {
  id        String @id @default(cuid())
  expenseId String
  userId    String
  amount    Int    // cents

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([userId])
}

model Account {
  id             String  @id @default(cuid())
  userId         String  // shared pool (primary user in couples)
  ownerUserId    String  // real owner (req.authUserId) — per-person attribution
  name           String
  type           String  @default("checking") // checking | savings | cash | investment | card
  currency       String  @default("EUR")
  currentBalance Int     @default(0) // cents; may be negative (cards/debt)
  isArchived     Boolean @default(false)
  sortOrder      Int     @default(0)

  // Household (Epic H2) — a bank account is only a data source. householdId links
  // it to a household; visibility controls whether other members can see it.
  householdId    String? // null = purely personal, not shared with a household
  visibility     String  @default("household") // private | household

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]
  incomes  Income[]

  @@index([userId, sortOrder])
}

model Income {
  id          String   @id @default(cuid())
  userId      String   // shared pool (primary user in couples)
  ownerUserId String   // who earned it (req.authUserId) — per-person attribution
  accountId   String? // account the income was paid into
  amount      Int // cents
  description String   @default("")
  merchant    String   @default("") // normalized form of description (reuses normalizeMerchant)
  category    String   @default("salary") // salary | freelance | transfer_in | other
  source      String   @default("manual") // "manual" | "import"
  externalId  String? // idempotency key for future bank import; null for manual entries
  date        DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@unique([userId, externalId]) // dedupe imported rows; multiple NULLs allowed in Postgres
  @@index([userId, accountId])
}

model CategorizationRule {
  id           String @id @default(cuid())
  userId       String
  matchType    String @default("contains") // "contains" | "equals" | "regex"
  pattern      String // matched against the expense merchant (contains/equals) or description (regex)
  allocationId String
  priority     Int    @default(0) // higher wins on conflict
  source       String @default("manual") // "manual" | "learned" (auto-created from a user correction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocation Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@unique([userId, matchType, pattern]) // one rule per (matchType, pattern); enables upsert on learning
  @@index([userId, priority])
}


model PlanDeposit {
  id      String @id @default(cuid())
  userId  String
  planId  String
  amount  Int // cents
  month   String // "2026-04"
  note    String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan LifePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, month])
}

model MonthlyBudget {
  id             String @id @default(cuid())
  userId         String
  allocationId   String
  month          String // "2026-04"
  allocatedAmount Int // cents

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocation Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@unique([allocationId, month])
}

model PartnerInvite {
  id           String   @id @default(cuid())
  senderId     String
  invitedEmail String
  token        String   @unique
  status       String   @default("pending") // pending | accepted
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  sender User @relation("SentInvites", fields: [senderId], references: [id], onDelete: Cascade)
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, type])
}

// ── Household (Epic H1) ──────────────────────────────────────────────
// A financial unit formed by one or more people. Replaces the "merge into the
// primary user's pool" hack (UserSettings.linkedUserId), which is kept in
// parallel during migration. Data ownership stays per-person; the household is
// the shared scope. visibilityTier default is "transparent" so migrated couples
// keep their current behaviour; new households are created as "shared_stats".
model Household {
  id             String @id @default(cuid())
  name           String
  financialModel String @default("shared")      // individual | proportional | shared
  visibilityTier String @default("transparent") // transparent | shared_stats | global_only
  baseCurrency   String @default("EUR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members HouseholdMember[]
}

model HouseholdMember {
  id                String  @id @default(cuid())
  householdId       String
  userId            String
  role              String  @default("member")  // owner | member
  status            String  @default("active")  // active | invited | left
  contributionBasis String @default("income")   // income | equal | custom
  customSharePct    Int?                          // basis points, when contributionBasis = custom

  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
}
