# Database
DATABASE_URL="postgresql://user@localhost:5432/lifeplan"

# JWT
JWT_SECRET="your-random-base64-secret-here"

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="onboarding@resend.dev"
# When you have a verified domain, change EMAIL_FROM to "LifePlan <noreply@yourdomain.com>"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback

# App
APP_URL="http://localhost:5173"
SERVER_PORT=3002
NODE_ENV=development

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PREMIUM_PRICE_ID=price_your_premium_price_id

# Optional: Hosted logo for emails
# LOGO_URL=https://yourdomain.com/logo.png
